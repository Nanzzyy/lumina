# Lumina OS — Environment Variables
# Copy to .env.local and fill in values.

# Admin password (plain text — use ADMIN_PASSWORD_HASH in production)
ADMIN_PASSWORD=lumina-studio-2026

# Admin password bcrypt hash (overrides ADMIN_PASSWORD). Generate with:
#   node -e "require('bcryptjs').hash('your-password',10).then(console.log)"
# ADMIN_PASSWORD_HASH=

# JWT secret key for session tokens. Change in production.
LUMINA_JWT_SECRET=

# Database path (default: dev.db in project root)
# LUMINA_DB_PATH=/data/lumina.db

# Asset storage directory (default: public/uploads)
# LUMINA_ASSET_DIR=/data/uploads

# Asset public base URL (default: /uploads)
# LUMINA_ASSET_PUBLIC_BASE=/uploads

# Asset storage backend (filesystem | s3). Default: filesystem
# LUMINA_ASSET_STORE=filesystem

# S3-compatible endpoint (when LUMINA_ASSET_STORE=s3)
# LUMINA_S3_ENDPOINT=
# LUMINA_S3_BUCKET=
# LUMINA_S3_REGION=
# LUMINA_S3_ACCESS_KEY=
# LUMINA_S3_SECRET_KEY=

# CDN base URL for assets (default: empty — served from app)
# LUMINA_ASSET_CDN_BASE=https://cdn.example.com

# Node environment
# NODE_ENV=production
